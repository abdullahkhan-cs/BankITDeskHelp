@model BankITDeskHelp.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Sign In - BankITDesk";
    Layout = "_Layout";
}

<div class="d-flex align-items-center justify-content-center" style="min-height: 80vh;">
    <div style="width: 100%; max-width: 420px;">
        <div class="card">
            <div class="card-body p-xl">
                <div class="text-center mb-xl">
                    <h2 class="mb-sm">Sign In</h2>
                    <p class="text-muted mb-0">BankITDesk IT Support Portal</p>
                </div>

                <form asp-action="Login" method="post">
                    <input type="hidden" name="returnUrl" value="@(ViewData["ReturnUrl"] ?? string.Empty)" />

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="form-group mb-lg">
                        <label asp-for="Email" class="form-label">Email Address</label>
                        <input asp-for="Email" class="form-control" placeholder="your.email@bank.com" />
                        <span asp-validation-for="Email" class="invalid-feedback"></span>
                    </div>

                    <div class="form-group mb-lg">
                        <label asp-for="Password" class="form-label">Password</label>
                        <input asp-for="Password" class="form-control" type="password" placeholder="••••••••" />
                        <span asp-validation-for="Password" class="invalid-feedback"></span>
                    </div>

                    <div class="flex justify-between items-center mb-lg">
                        <div class="form-check">
                            <input asp-for="RememberMe" class="form-check-input" id="rememberMe" />
                            <label class="form-check-label" for="rememberMe">Remember me</label>
                        </div>
                        <a href="#" class="text-sm text-decoration-none">Forgot password?</a>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 btn-lg">Sign In</button>
                </form>

                <div class="text-center mt-xl">
                    <p class="text-muted text-sm mb-0">
                        Need assistance? Contact <a href="#" class="text-decoration-none">IT Support</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
