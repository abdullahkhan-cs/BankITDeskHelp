@model BankITDeskHelp.ViewModels.AssignComplaintViewModel
@{
    ViewData["Title"] = "Assign Complaint";
}

<div class="container py-4">
    <h3 class="fw-bold mb-4">Assign Complaint — @Model.TicketNumber</h3>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <div class="row mb-2">
                <div class="col-md-4"><strong>Employee:</strong> @Model.EmployeeName</div>
                <div class="col-md-4"><strong>Department:</strong> @Model.DepartmentName</div>
                <div class="col-md-4"><strong>Priority:</strong> @Model.Priority</div>
            </div>
            <div><strong>Description:</strong> @Model.Description</div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <form asp-action="Assign" method="post">
                <input type="hidden" asp-for="ComplaintId" />
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="mb-3">
                    <label class="form-label">Assign to Manager</label>
                    <select asp-for="SelectedManagerId" class="form-select">
                        <option value="">-- Select Manager --</option>
                        @foreach (var m in Model.Managers ?? new List<BankITDeskHelp.Models.ApplicationUser>())
                        {
                            <option value="@m.Id">@m.FullName (@m.Email)</option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Remarks (optional)</label>
                    <textarea asp-for="Remarks" class="form-control" rows="2"></textarea>
                </div>

                <button type="submit" class="btn btn-primary">Assign Ticket</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </form>
        </div>
    </div>
</div>