@model List<BankITDeskHelp.Models.Complaint>
@{
    ViewData["Title"] = "Dashboard";
}

<div class="dashboard-actions mb-lg">
    <div class="btn-group">
        <a asp-action="Assign" class="btn btn-outline-primary">Bulk Assign</a>
        <a asp-action="Verify" class="btn btn-primary">Verify Tickets</a>
        <form asp-action="EnsureManagers" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-success">Ensure Managers</button>
        </form>
    </div>
</div>

<div class="grid grid-cols-5 gap-lg mb-lg">
    <div class="kpi-card">
        <div class="kpi-label">New Tickets</div>
        <div class="kpi-value">@ViewBag.NewCount</div>
    </div>
    <div class="kpi-card info">
        <div class="kpi-label">Assigned</div>
        <div class="kpi-value">@ViewBag.AssignedCount</div>
    </div>
    <div class="kpi-card warning">
        <div class="kpi-label">In Progress</div>
        <div class="kpi-value">@ViewBag.InProgressCount</div>
    </div>
    <div class="kpi-card success">
        <div class="kpi-label">Resolved</div>
        <div class="kpi-value">@ViewBag.ResolvedCount</div>
    </div>
    <div class="kpi-card danger">
        <div class="kpi-label">Closed</div>
        <div class="kpi-value">@ViewBag.ClosedCount</div>
    </div>
</div>

<div class="grid grid-cols-2 gap-lg mb-lg">
    <div class="card">
        <div class="card-header">
            <h3 class="mb-0">Tickets Overview</h3>
        </div>
        <div class="card-body">
            <div style="height: 280px;">
                <canvas id="adminChart"></canvas>
            </div>
        </div>
    </div>
    <div class="card">
        <div class="card-header">
            <h3 class="mb-0">Quick Stats</h3>
        </div>
        <div class="card-body">
            <div class="flex flex-col gap-md">
                <div class="flex justify-between items-center">
                    <span class="text-secondary">Total Tickets</span>
                    <span class="font-weight-bold">@Model.Count</span>
                </div>
                <div class="flex justify-between items-center">
                    <span class="text-secondary">This Week</span>
                    <span class="font-weight-bold text-primary">+12%</span>
                </div>
                <div class="flex justify-between items-center">
                    <span class="text-secondary">Avg Resolution Time</span>
                    <span class="font-weight-bold">2.5 days</span>
                </div>
                <div class="flex justify-between items-center">
                    <span class="text-secondary">Active Managers</span>
                    <span class="font-weight-bold text-success">8</span>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <div class="flex justify-between items-center">
            <h3 class="mb-0">Recent Complaints</h3>
            <a asp-action="Assign" class="btn btn-sm btn-outline-primary">View All</a>
        </div>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Ticket ID</th>
                        <th>Subject</th>
                        <th>Department</th>
                        <th>Branch</th>
                        <th>Priority</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model)
                    {
                        <tr>
                            <td><strong>@c.TicketNumber</strong></td>
                            <td>@c.Subject</td>
                            <td>@c.Department?.Name</td>
                            <td>@c.Branch?.Name</td>
                            <td>
                                @switch (c.Priority)
                                {
                                    case BankITDeskHelp.Models.PriorityLevel.Low:
                                        <span class="badge badge-secondary">Low</span>
                                        break;
                                    case BankITDeskHelp.Models.PriorityLevel.Medium:
                                        <span class="badge badge-info">Medium</span>
                                        break;
                                    case BankITDeskHelp.Models.PriorityLevel.High:
                                        <span class="badge badge-warning">High</span>
                                        break;
                                    case BankITDeskHelp.Models.PriorityLevel.Critical:
                                        <span class="badge badge-danger">Critical</span>
                                        break;
                                }
                            </td>
                            <td>
                                @switch (c.Status.ToString())
                                {
                                    case "New":
                                        <span class="badge badge-secondary">@c.Status</span>
                                        break;
                                    case "Assigned":
                                        <span class="badge badge-info">@c.Status</span>
                                        break;
                                    case "InProgress":
                                        <span class="badge badge-warning">@c.Status</span>
                                        break;
                                    case "Resolved":
                                        <span class="badge badge-success">@c.Status</span>
                                        break;
                                    case "Closed":
                                        <span class="badge badge-danger">@c.Status</span>
                                        break;
                                    default:
                                        <span class="badge badge-secondary">@c.Status</span>
                                        break;
                                }
                            </td>
                            <td>@c.CreatedAt.ToString("dd MMM yyyy")</td>
                            <td>
                                @if (c.Status == BankITDeskHelp.Models.ComplaintStatus.New)
                                {
                                    <a asp-action="Assign" asp-route-id="@c.Id" class="btn btn-sm btn-outline-primary">Assign</a>
                                }
                                else if (c.Status == BankITDeskHelp.Models.ComplaintStatus.Resolved)
                                {
                                    <a asp-action="Verify" asp-route-id="@c.Id" class="btn btn-sm btn-success">Verify</a>
                                }
                                else
                                {
                                    <a asp-action="Verify" asp-route-id="@c.Id" class="btn btn-sm btn-outline-primary">View</a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        async function loadAdminMetrics() {
            const res = await fetch('/Admin/DashboardData');
            if (!res.ok) return;
            const metrics = await res.json();

            const ctx = document.getElementById('adminChart').getContext('2d');
            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: metrics.statusLabels,
                    datasets: [{
                        label: 'Tickets',
                        data: metrics.statusCounts,
                        backgroundColor: ['#6366f1', '#3b82f6', '#f59e0b', '#10b981', '#ef4444'],
                        borderRadius: 8,
                        borderSkipped: false,
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: false
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: {
                                color: '#e5e7eb'
                            }
                        },
                        x: {
                            grid: {
                                display: false
                            }
                        }
                    }
                }
            });
        }
        document.addEventListener('DOMContentLoaded', loadAdminMetrics);
    </script>
}
