@model BankITDeskHelp.ViewModels.AdminVerifyViewModel
@{
    ViewData["Title"] = "Verify Resolution";
}

<div class="container py-4">
    <h3 class="fw-bold mb-1">@Model.TicketNumber — @Model.Subject</h3>
    <span class="badge bg-secondary mb-4">@Model.Status</span>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body">
                    <div class="row mb-2">
                        <div class="col-md-4"><strong>Employee:</strong> @Model.EmployeeName</div>
                        <div class="col-md-4"><strong>Department:</strong> @Model.DepartmentName</div>
                        <div class="col-md-4"><strong>Manager:</strong> @Model.AssignedManagerName</div>
                    </div>
                    <div class="mb-2"><strong>Priority:</strong> @Model.Priority</div>
                    <div><strong>Description:</strong> @Model.Description</div>

                    @if (Model.Attachments.Any())
                    {
                        <div class="mt-3">
                            <strong>Attachments:</strong>
                            <ul>
                                @foreach (var a in Model.Attachments)
                                {
                                    <li><a href="@a.FilePath" target="_blank">@a.FileName</a></li>
                                }
                            </ul>
                        </div>
                    }
                </div>
            </div>

            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white fw-bold">Manager Remarks</div>
                <div class="card-body">
                    <p class="mb-0">@(Model.ManagerRemarks ?? "No remarks provided.")</p>
                </div>
            </div>

            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white fw-bold">Comments</div>
                <div class="card-body">
                    @if (!Model.Comments.Any())
                    {
                        <p class="text-muted mb-0">No comments yet.</p>
                    }
                    @foreach (var c in Model.Comments)
                    {
                        <div class="border-bottom pb-2 mb-2">
                            <small class="text-muted">@c.CreatedAt.ToString("dd MMM yyyy, h:mm tt")</small>
                            <p class="mb-0">@c.Text</p>
                        </div>
                    }
                </div>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-header bg-white fw-bold">Timeline</div>
                <div class="card-body">
                    <ul class="list-unstyled mb-0">
                        @foreach (var h in Model.Histories)
                        {
                            <li class="mb-2">
                                <strong>@h.Action</strong> — <small class="text-muted">@h.Timestamp.ToString("dd MMM yyyy, h:mm tt")</small>
                                @if (!string.IsNullOrEmpty(h.Details))
                                {
                                    <div class="text-muted small">@h.Details</div>
                                }
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h6 class="fw-bold mb-3">Decision</h6>

                    @if (Model.Status == BankITDeskHelp.Models.ComplaintStatus.Resolved)
                    {
                        <form asp-action="CloseTicket" method="post" class="mb-2">
                            <input type="hidden" name="id" value="@Model.ComplaintId" />
                            <button type="submit" class="btn btn-success w-100">Close Ticket</button>
                        </form>

                        <form asp-action="Reassign" method="post">
                            <input type="hidden" name="id" value="@Model.ComplaintId" />
                            <button type="submit" class="btn btn-outline-warning w-100">Reassign to Manager</button>
                        </form>
                    }
                    else if (Model.Status == BankITDeskHelp.Models.ComplaintStatus.Closed)
                    {
                        <p class="text-success fw-bold mb-0">✅ This ticket is Closed.</p>
                    }
                    else
                    {
                        <p class="text-muted mb-0">Ticket not yet resolved by Manager.</p>
                    }

                    <a asp-action="Index" class="btn btn-outline-secondary w-100 mt-3">Back to Dashboard</a>
                </div>
            </div>
        </div>
    </div>
</div>