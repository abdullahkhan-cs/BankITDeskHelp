@model BankITDeskHelp.ViewModels.AdminVerifyViewModel
@{
    ViewData["Title"] = "Verify Resolution";
}

<div class="page-header">
    <h1>@Model.TicketNumber — @Model.Subject</h1>
    <p class="page-header-subtitle">Review and verify ticket resolution</p>
</div>

<div class="flex items-center gap-md mb-xl">
    @switch (Model.Status.ToString())
    {
        case "Resolved":
            <span class="badge badge-success badge-lg">@Model.Status</span>
            break;
        case "Closed":
            <span class="badge badge-danger badge-lg">@Model.Status</span>
            break;
        default:
            <span class="badge badge-secondary badge-lg">@Model.Status</span>
            break;
    }
</div>

<div class="grid grid-cols-3 gap-xl">
    <div class="col-span-2">
        <div class="card mb-xl">
            <div class="card-header">
                <h3 class="mb-0">Ticket Information</h3>
            </div>
            <div class="card-body">
                <div class="grid grid-cols-3 gap-lg mb-lg">
                    <div>
                        <small class="text-muted">Employee</small>
                        <div class="font-weight-semibold">@Model.EmployeeName</div>
                    </div>
                    <div>
                        <small class="text-muted">Department</small>
                        <div class="font-weight-semibold">@Model.DepartmentName</div>
                    </div>
                    <div>
                        <small class="text-muted">Manager</small>
                        <div class="font-weight-semibold">@Model.AssignedManagerName</div>
                    </div>
                </div>
                <div class="mb-lg">
                    <small class="text-muted">Priority</small>
                    <div class="font-weight-semibold">@Model.Priority</div>
                </div>
                <div class="mb-lg">
                    <small class="text-muted">Description</small>
                    <div>@Model.Description</div>
                </div>

                @if (Model.Attachments.Any())
                {
                    <div>
                        <small class="text-muted">Attachments</small>
                        <ul class="mb-0">
                            @foreach (var a in Model.Attachments)
                            {
                                <li><a href="@a.FilePath" target="_blank" class="text-decoration-none">@a.FileName</a></li>
                            }
                        </ul>
                    </div>
                }
            </div>
        </div>

        <div class="card mb-xl">
            <div class="card-header">
                <h3 class="mb-0">Manager Remarks</h3>
            </div>
            <div class="card-body">
                <p class="mb-0">@(Model.ManagerRemarks ?? "No remarks provided.")</p>
            </div>
        </div>

        <div class="card mb-xl">
            <div class="card-header">
                <h3 class="mb-0">Comments</h3>
            </div>
            <div class="card-body">
                @if (!Model.Comments.Any())
                {
                    <p class="text-muted mb-0">No comments yet.</p>
                }
                @foreach (var c in Model.Comments)
                {
                    <div class="border-bottom pb-lg mb-lg">
                        <small class="text-muted">@c.CreatedAt.ToString("dd MMM yyyy, h:mm tt")</small>
                        <p class="mb-0">@c.Text</p>
                    </div>
                }
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h3 class="mb-0">Timeline</h3>
            </div>
            <div class="card-body">
                <ul class="list-unstyled mb-0">
                    @foreach (var h in Model.Histories)
                    {
                        <li class="mb-lg">
                            <div class="font-weight-semibold">@h.Action</div>
                            <small class="text-muted">@h.Timestamp.ToString("dd MMM yyyy, h:mm tt")</small>
                            @if (!string.IsNullOrEmpty(h.Details))
                            {
                                <div class="text-muted small mt-sm">@h.Details</div>
                            }
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>

    <div>
        <div class="card">
            <div class="card-header">
                <h3 class="mb-0">Decision</h3>
            </div>
            <div class="card-body">
                @if (Model.Status == BankITDeskHelp.Models.ComplaintStatus.Resolved)
                {
                    <form asp-action="CloseTicket" method="post" class="mb-lg">
                        <input type="hidden" name="id" value="@Model.ComplaintId" />
                        <button type="submit" class="btn btn-success w-100">Close Ticket</button>
                    </form>

                    <form asp-action="Reassign" method="post" class="mb-lg">
                        <input type="hidden" name="id" value="@Model.ComplaintId" />
                        <button type="submit" class="btn btn-warning w-100">Reassign to Manager</button>
                    </form>
                }
                else if (Model.Status == BankITDeskHelp.Models.ComplaintStatus.Closed)
                {
                    <div class="alert alert-success">
                        <strong>Closed</strong> — This ticket has been closed.
                    </div>
                }
                else
                {
                    <p class="text-muted mb-0">Ticket not yet resolved by Manager.</p>
                }

                <a asp-action="Index" class="btn btn-outline-secondary w-100">Back to Dashboard</a>
            </div>
        </div>
    </div>
</div>