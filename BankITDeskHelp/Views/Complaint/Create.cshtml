@model BankITDeskHelp.ViewModels.ComplaintCreateViewModel
@{
    ViewData["Title"] = "Create Complaint";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h3 class="mb-1 fw-bold">Submit a Complaint</h3>
                    <p class="text-muted mb-4">Fill in the details below and our IT team will get back to you.</p>

                    <form asp-action="Create" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none" id="validationSummary"></div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Employee Name</label>
                                <input asp-for="EmployeeName" class="form-control" placeholder="John Doe" />
                                <span asp-validation-for="EmployeeName" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Employee ID</label>
                                <input asp-for="EmployeeId" class="form-control" placeholder="EMP-1023" />
                                <span asp-validation-for="EmployeeId" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Branch</label>
                                <select asp-for="BranchId" class="form-select"
                                        asp-items="@(new SelectList(Model.Branches, "Id", "Name"))">
                                    <option value="">-- Select Branch --</option>
                                </select>
                                <span asp-validation-for="BranchId" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Department</label>
                                <select asp-for="DepartmentId" class="form-select"
                                        asp-items="@(new SelectList(Model.Departments, "Id", "Name"))">
                                    <option value="">-- Select Department --</option>
                                </select>
                                <span asp-validation-for="DepartmentId" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Email</label>
                                <input asp-for="Email" class="form-control" placeholder="you@bank.com" />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Phone (optional)</label>
                                <input asp-for="Phone" class="form-control" placeholder="0300-1234567" />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Category</label>
                                <select asp-for="CategoryId" class="form-select"
                                        asp-items="@(new SelectList(Model.Categories, "Id", "Name"))">
                                    <option value="">-- Select Category --</option>
                                </select>
                                <span asp-validation-for="CategoryId" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Priority</label>
                                <select asp-for="Priority" class="form-select"
                                        asp-items="Html.GetEnumSelectList<BankITDeskHelp.Models.PriorityLevel>()">
                                </select>
                            </div>

                            <div class="col-12">
                                <label class="form-label">Subject</label>
                                <input asp-for="Subject" class="form-control" placeholder="Brief summary of the issue" />
                                <span asp-validation-for="Subject" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label class="form-label">Description</label>
                                <textarea asp-for="Description" class="form-control" rows="4" placeholder="Describe your issue in detail..."></textarea>
                                <span asp-validation-for="Description" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label class="form-label">Attachment (optional)</label>
                                <input asp-for="Attachment" type="file" class="form-control" />
                            </div>
                        </div>

                        <div class="d-grid mt-4">
                            <button type="submit" class="btn btn-primary btn-lg">Submit Complaint</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}