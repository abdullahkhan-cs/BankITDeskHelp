@model BankITDeskHelp.Models.Complaint
@{
    ViewData["Title"] = "Lodge a Complaint - BankITDesk";
}

<div class="page-header">
    <h1>Lodge a Complaint</h1>
    <p class="page-header-subtitle">Submit a new IT support ticket to our team</p>
</div>

<div class="card">
    <div class="card-body">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <form asp-action="Create" method="post" enctype="multipart/form-data">
            <h4 class="mb-lg font-weight-semibold">Personal Information</h4>
            <hr class="mb-lg" />

            <div class="grid grid-cols-2 gap-lg mb-lg">
                <div class="form-group">
                    <label asp-for="EmployeeName" class="form-label">Employee Name <span class="text-danger">*</span></label>
                    <input asp-for="EmployeeName" class="form-control" placeholder="John Doe" required />
                    <span asp-validation-for="EmployeeName" class="invalid-feedback"></span>
                </div>

                <div class="form-group">
                    <label asp-for="EmployeeId" class="form-label">Employee ID <span class="text-danger">*</span></label>
                    <input asp-for="EmployeeId" class="form-control" placeholder="EMP12345" required />
                    <span asp-validation-for="EmployeeId" class="invalid-feedback"></span>
                </div>
            </div>

            <div class="grid grid-cols-2 gap-lg mb-lg">
                <div class="form-group">
                    <label asp-for="Email" class="form-label">Email Address <span class="text-danger">*</span></label>
                    <input asp-for="Email" type="email" class="form-control" placeholder="your.email@bank.com" required />
                    <span asp-validation-for="Email" class="invalid-feedback"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Phone" class="form-label">Phone Number</label>
                    <input asp-for="Phone" type="tel" class="form-control" placeholder="Extension or mobile number" />
                    <span asp-validation-for="Phone" class="invalid-feedback"></span>
                </div>
            </div>

            <h4 class="mb-lg font-weight-semibold">Location Information</h4>
            <hr class="mb-lg" />

            <div class="grid grid-cols-2 gap-lg mb-lg">
                <div class="form-group">
                    <label asp-for="DepartmentId" class="form-label">Department <span class="text-danger">*</span></label>
                    <select asp-for="DepartmentId" class="form-select" required>
                        <option value="">-- Select Department --</option>
                        @foreach (var dept in ViewBag.Departments ?? new List<dynamic>())
                        {
                            <option value="@dept.Id">@dept.Name</option>
                        }
                    </select>
                    <span asp-validation-for="DepartmentId" class="invalid-feedback"></span>
                </div>

                <div class="form-group">
                    <label asp-for="BranchId" class="form-label">Branch <span class="text-danger">*</span></label>
                    <select asp-for="BranchId" class="form-select" required>
                        <option value="">-- Select Branch --</option>
                        @foreach (var branch in ViewBag.Branches ?? new List<dynamic>())
                        {
                            <option value="@branch.Id">@branch.Name</option>
                        }
                    </select>
                    <span asp-validation-for="BranchId" class="invalid-feedback"></span>
                </div>
            </div>

            <h4 class="mb-lg font-weight-semibold">Complaint Details</h4>
            <hr class="mb-lg" />

            <div class="form-group mb-lg">
                <label asp-for="Subject" class="form-label">Subject <span class="text-danger">*</span></label>
                <input asp-for="Subject" class="form-control" maxlength="200" placeholder="Brief summary of the issue" required />
                <span asp-validation-for="Subject" class="invalid-feedback"></span>
                <small class="text-muted">Max 200 characters</small>
            </div>

            <div class="form-group mb-lg">
                <label asp-for="Description" class="form-label">Description <span class="text-danger">*</span></label>
                <textarea asp-for="Description" class="form-control" rows="4" placeholder="Provide detailed information about the issue..." required></textarea>
                <span asp-validation-for="Description" class="invalid-feedback"></span>
                <small class="text-muted">Please be as detailed as possible</small>
            </div>

            <div class="form-group mb-lg">
                <label class="form-label">Attachment</label>
                <input type="file" name="Attachment" class="form-control" accept=".pdf,.doc,.docx,.xls,.xlsx,.png,.jpg,.jpeg" />
                <small class="text-muted">Supported formats: PDF, DOC, XLS, PNG, JPG (Max 5MB)</small>
            </div>

            <div class="flex justify-center gap-md mt-xl pt-lg border-top">
                <button type="submit" class="btn btn-primary btn-lg">Submit Complaint</button>
                <a asp-controller="Home" asp-action="Index" class="btn btn-secondary btn-lg">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
