@{
    ViewData["Title"] = "BankITDesk - IT Support Portal";
}

<div class="landing-container">
    <!-- Hero Section -->
    <div class="hero-section">
        <div class="hero-content">
            <div class="hero-badge">
                <span class="badge badge-primary-filled">Enterprise IT Support</span>
            </div>
            <h1 class="hero-title">Streamline Your IT Support Workflow</h1>
            <p class="hero-subtitle">
                Submit IT support requests, track ticket progress, and resolve technical issues efficiently with our enterprise ticketing system designed for banking operations.
            </p>
            <div class="hero-actions">
                <a asp-controller="Account" asp-action="Login" asp-route-returnUrl="/Admin/Index" class="btn btn-primary btn-lg">
                    Sign In to Dashboard
                </a>
                <a href="#quickComplaint" class="btn btn-outline-primary btn-lg">
                    Submit a Ticket
                </a>
            </div>
        </div>
    </div>

    <!-- Features Section -->
    <div class="features-section">
        <div class="grid grid-cols-4 gap-lg">
            <div class="feature-card">
                <div class="feature-icon">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"/>
                        <polyline points="12 6 12 12 16 14"/>
                    </svg>
                </div>
                <h3 class="feature-title">Fast Tracking</h3>
                <p class="feature-description">Real-time ticket updates and status notifications for complete visibility</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
                        <circle cx="9" cy="7" r="4"/>
                        <path d="M23 21v-2a4 4 0 00-3-3.87"/>
                        <path d="M16 3.13a4 4 0 010 7.75"/>
                    </svg>
                </div>
                <h3 class="feature-title">Expert Support</h3>
                <p class="feature-description">Dedicated IT managers for each department ensuring specialized assistance</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="18" y1="20" x2="18" y2="10"/>
                        <line x1="12" y1="20" x2="12" y2="4"/>
                        <line x1="6" y1="20" x2="6" y2="14"/>
                    </svg>
                </div>
                <h3 class="feature-title">Analytics</h3>
                <p class="feature-description">Comprehensive performance reports and metrics for data-driven decisions</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                        <path d="M7 11V7a5 5 0 0110 0v4"/>
                    </svg>
                </div>
                <h3 class="feature-title">Secure</h3>
                <p class="feature-description">Enterprise-grade security and compliance for banking industry standards</p>
            </div>
        </div>
    </div>

    <!-- Quick Ticket Form -->
    <div class="ticket-form-section" id="quickComplaint">
        <div class="card">
            <div class="card-header">
                <h3 class="mb-0">Quick Ticket Submission</h3>
            </div>
            <div class="card-body">
                <form asp-controller="Complaint" asp-action="Create" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()

                    <div class="grid grid-cols-2 gap-lg mb-lg">
                        <div class="form-group">
                            <label class="form-label">Employee Name <span class="text-danger">*</span></label>
                            <input type="text" name="EmployeeName" class="form-control" required placeholder="Enter your full name" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Employee ID <span class="text-danger">*</span></label>
                            <input type="text" name="EmployeeId" class="form-control" required placeholder="Enter your employee ID" />
                        </div>
                    </div>

                    <div class="grid grid-cols-2 gap-lg mb-lg">
                        <div class="form-group">
                            <label class="form-label">Email Address <span class="text-danger">*</span></label>
                            <input type="email" name="Email" class="form-control" required placeholder="your.email@bank.com" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Phone Number</label>
                            <input type="tel" name="Phone" class="form-control" placeholder="Extension or mobile number" />
                        </div>
                    </div>

                    <div class="grid grid-cols-2 gap-lg mb-lg">
                        <div class="form-group">
                            <label class="form-label">Department <span class="text-danger">*</span></label>
                            <select name="DepartmentId" class="form-select" required>
                                <option value="">-- Select Department --</option>
                                @foreach (var dept in ViewBag.Departments ?? new List<dynamic>())
                                {
                                    <option value="@dept.Id">@dept.Name</option>
                                }
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Branch <span class="text-danger">*</span></label>
                            <select name="BranchId" class="form-select" required>
                                <option value="">-- Select Branch --</option>
                                @foreach (var branch in ViewBag.Branches ?? new List<dynamic>())
                                {
                                    <option value="@branch.Id">@branch.Name</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="grid grid-cols-2 gap-lg mb-lg">
                        <div class="form-group">
                            <label class="form-label">Category <span class="text-danger">*</span></label>
                            <select name="CategoryId" class="form-select" required>
                                <option value="">-- Select Category --</option>
                                @foreach (var cat in ViewBag.Categories ?? new List<dynamic>())
                                {
                                    <option value="@cat.Id">@cat.Name</option>
                                }
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Priority <span class="text-danger">*</span></label>
                            <select name="Priority" class="form-select" required>
                                <option value="">-- Select Priority --</option>
                                <option value="0">Low</option>
                                <option value="1" selected>Medium</option>
                                <option value="2">High</option>
                                <option value="3">Critical</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-group mb-lg">
                        <label class="form-label">Subject <span class="text-danger">*</span></label>
                        <input type="text" name="Subject" class="form-control" maxlength="200" required placeholder="Brief summary of the issue" />
                    </div>

                    <div class="form-group mb-lg">
                        <label class="form-label">Description <span class="text-danger">*</span></label>
                        <textarea name="Description" class="form-control" rows="4" required placeholder="Provide detailed information about the issue..."></textarea>
                    </div>

                    <div class="form-group mb-lg">
                        <label class="form-label">Attachment (optional)</label>
                        <input type="file" name="Attachment" class="form-control" />
                        <small class="text-muted">Supported formats: PDF, DOC, XLS, PNG, JPG (Max 5MB)</small>
                    </div>

                    <div class="flex justify-center gap-md">
                        <button type="submit" class="btn btn-primary btn-lg">Submit Ticket</button>
                        <button type="reset" class="btn btn-secondary btn-lg">Clear Form</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
