@model BankITDeskHelp.ViewModels.ManagerTicketDetailsViewModel
@{
    ViewData["Title"] = "Ticket Details";
}

<div class="container py-4">
    <h3 class="fw-bold mb-1">@Model.TicketNumber — @Model.Subject</h3>
    <span class="badge bg-secondary mb-4">@Model.Status</span>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body">
                    <div class="row mb-2">
                        <div class="col-md-4"><strong>Employee:</strong> @Model.EmployeeName</div>
                        <div class="col-md-4"><strong>Department:</strong> @Model.DepartmentName</div>
                        <div class="col-md-4"><strong>Branch:</strong> @Model.BranchName</div>
                    </div>
                    <div class="mb-2"><strong>Priority:</strong> @Model.Priority</div>
                    <div><strong>Description:</strong> @Model.Description</div>

                    @if (Model.Attachments.Any())
                    {
                        <div class="mt-3">
                            <strong>Attachments:</strong>
                            <ul>
                                @foreach (var a in Model.Attachments)
                                {
                                    <li><a href="@a.FilePath" target="_blank">@a.FileName</a></li>
                                }
                            </ul>
                        </div>
                    }
                </div>
            </div>

            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white fw-bold">Comments</div>
                <div class="card-body">
                    @foreach (var c in Model.Comments)
                    {
                        <div class="border-bottom pb-2 mb-2">
                            <small class="text-muted">@c.CreatedAt.ToString("dd MMM yyyy, h:mm tt")</small>
                            <p class="mb-0">@c.Text</p>
                        </div>
                    }

                    <form asp-action="AddComment" method="post" class="mt-3">
                        <input type="hidden" name="complaintId" value="@Model.ComplaintId" />
                        <textarea name="newComment" class="form-control mb-2" rows="2" placeholder="Add a comment..."></textarea>
                        <button type="submit" class="btn btn-sm btn-outline-primary">Add Comment</button>
                    </form>
                </div>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-header bg-white fw-bold">Timeline</div>
                <div class="card-body">
                    <ul class="list-unstyled mb-0">
                        @foreach (var h in Model.Histories)
                        {
                            <li class="mb-2">
                                <strong>@h.Action</strong> — <small class="text-muted">@h.Timestamp.ToString("dd MMM yyyy, h:mm tt")</small>
                                @if (!string.IsNullOrEmpty(h.Details))
                                {
                                    <div class="text-muted small">@h.Details</div>
                                }
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h6 class="fw-bold mb-3">Actions</h6>

                    @if (Model.Status == BankITDeskHelp.Models.ComplaintStatus.Assigned)
                    {
                        <form asp-action="StartWork" method="post" class="mb-2">
                            <input type="hidden" name="id" value="@Model.ComplaintId" />
                            <button type="submit" class="btn btn-warning w-100">Start Work</button>
                        </form>
                    }

                    @if (Model.Status == BankITDeskHelp.Models.ComplaintStatus.InProgress)
                    {
                        <form asp-action="Resolve" method="post">
                            <input type="hidden" name="complaintId" value="@Model.ComplaintId" />
                            <textarea name="managerRemarks" class="form-control mb-2" rows="2" placeholder="Resolution remarks..."></textarea>
                            <button type="submit" class="btn btn-success w-100">Resolve Ticket</button>
                        </form>
                    }

                    @if (Model.Status == BankITDeskHelp.Models.ComplaintStatus.Resolved)
                    {
                        <p class="text-success fw-bold">✅ Resolved — awaiting Admin verification</p>
                    }

                    <a asp-action="Index" class="btn btn-outline-secondary w-100 mt-2">Back to List</a>
                </div>
            </div>
        </div>
    </div>
</div>