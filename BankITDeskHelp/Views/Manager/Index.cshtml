@model List<BankITDeskHelp.Models.Complaint>
@{
    ViewData["Title"] = "Manager Dashboard";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold">My Assigned Tickets</h3>
        <div>
            <a asp-controller="Manager" asp-action="Index" class="btn btn-outline-secondary me-2">Refresh</a>
            <a asp-controller="Manager" asp-action="Details" class="btn btn-primary">My Performance</a>
            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline ms-2">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-danger">Logout</button>
            </form>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card text-center shadow-sm border-0 bg-info text-white p-3">
                <div class="card-body">
                    <div class="small text-muted">Assigned</div>
                    <h2 class="fw-bold">@ViewBag.AssignedCount</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center shadow-sm border-0 bg-warning text-dark p-3">
                <div class="card-body">
                    <div class="small text-muted">Working</div>
                    <h2 class="fw-bold">@ViewBag.WorkingCount</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center shadow-sm border-0 bg-success text-white p-3">
                <div class="card-body">
                    <div class="small text-muted">Resolved Today</div>
                    <h2 class="fw-bold">@ViewBag.ResolvedTodayCount</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center shadow-sm border-0 bg-secondary text-white p-3">
                <div class="card-body">
                    <div class="small text-muted">Pending</div>
                    <h2 class="fw-bold">@ViewBag.PendingCount</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8 mb-4">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h5 class="fw-bold">My Tickets</h5>
                    <canvas id="managerChart" style="height:220px;"></canvas>
                </div>
            </div>
        </div>
        <div class="col-lg-4 mb-4">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h5 class="fw-bold">Quick Actions</h5>
                    <a asp-controller="Complaint" asp-action="Create" class="btn btn-outline-primary w-100 mb-2">Create Ticket</a>
                    <a asp-controller="Manager" asp-action="Index" class="btn btn-outline-secondary w-100">View My Tickets</a>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Ticket</th>
                        <th>Employee</th>
                        <th>Department</th>
                        <th>Priority</th>
                        <th>Created</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model)
                    {
                        <tr>
                            <td>@c.TicketNumber</td>
                            <td>@c.EmployeeName</td>
                            <td>@c.Department?.Name</td>
                            <td>@c.Priority</td>
                            <td>@c.CreatedAt.ToString("dd MMM yyyy")</td>
                            <td><span class="badge bg-secondary">@c.Status</span></td>
                            <td>
                                <a asp-action="Details" asp-route-id="@c.Id" class="btn btn-sm btn-outline-primary">View</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        var ctx = document.getElementById('managerChart').getContext('2d');
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: ['Week 1','Week 2','Week 3','Week 4'],
                datasets: [{
                    label: 'Resolved',
                    data: [@ViewBag.ResolvedThisWeek, @ViewBag.ResolvedLastWeek, 2, 3],
                    borderColor: '#28a745',
                    fill: false
                }]
            }
        });
    </script>
}
