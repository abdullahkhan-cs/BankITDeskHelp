@model List<BankITDeskHelp.Models.Complaint>
@{
    ViewData["Title"] = "Manager Dashboard - BankITDesk";
}

<div class="page-header">
    <h1>My Assigned Tickets</h1>
    <p class="page-header-subtitle">Manage and track your assigned support tickets</p>
</div>

<div class="flex justify-between items-center mb-xl flex-wrap gap-md">
    <div class="btn-group">
        <a asp-action="Index" class="btn btn-outline-primary">Refresh</a>
        <a asp-action="Details" class="btn btn-primary">My Performance</a>
    </div>
</div>

<div class="grid grid-cols-4 gap-lg mb-xl">
    <div class="kpi-card">
        <div class="kpi-label">Assigned</div>
        <div class="kpi-value">@ViewBag.AssignedCount</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-label">Working</div>
        <div class="kpi-value">@ViewBag.WorkingCount</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-label">Resolved Today</div>
        <div class="kpi-value">@ViewBag.ResolvedTodayCount</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-label">Pending</div>
        <div class="kpi-value">@ViewBag.PendingCount</div>
    </div>
</div>

<div class="card mb-xl">
    <div class="card-header">
        <h3 class="mb-0">Performance Metrics</h3>
    </div>
    <div class="card-body">
        <div style="height: 300px;">
            <canvas id="managerChart"></canvas>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h3 class="mb-0">Your Tickets</h3>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>Ticket</th>
                        <th>Employee</th>
                        <th>Department</th>
                        <th>Priority</th>
                        <th>Created</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model)
                    {
                        <tr>
                            <td><strong>@c.TicketNumber</strong></td>
                            <td>@c.EmployeeName</td>
                            <td>@c.Department?.Name</td>
                            <td>@c.Priority</td>
                            <td>@c.CreatedAt.ToString("dd MMM yyyy")</td>
                            <td>
                                @switch (c.Status.ToString())
                                {
                                    case "Assigned":
                                        <span class="badge badge-info">@c.Status</span>
                                        break;
                                    case "InProgress":
                                        <span class="badge badge-warning">@c.Status</span>
                                        break;
                                    case "Resolved":
                                        <span class="badge badge-success">@c.Status</span>
                                        break;
                                    default:
                                        <span class="badge badge-secondary">@c.Status</span>
                                        break;
                                }
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@c.Id" class="btn btn-sm btn-outline-primary">View</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        var ctx = document.getElementById('managerChart').getContext('2d');
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: ['Week 1', 'Week 2', 'Week 3', 'Week 4'],
                datasets: [{
                    label: 'Tickets Resolved',
                    data: [3, 5, 4, 6],
                    borderColor: '#6366f1',
                    backgroundColor: 'rgba(99, 102, 241, 0.1)',
                    fill: true,
                    tension: 0.4
                }]
            },
            options: { responsive: true, maintainAspectRatio: false }
        });
    </script>
}
